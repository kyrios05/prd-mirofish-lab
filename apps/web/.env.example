# PRD MiroFish Lab — Frontend environment variables
#
# Copy this file to .env.local and adjust values for your environment.
# .env.local is gitignored; .env.example is committed as documentation.
#
# Usage:
#   cp .env.example .env.local
#   # edit .env.local as needed
#   npm run dev

# Backend API base URL.
# For local development the default value (http://localhost:8000) is used
# when this variable is unset.
# Change to your deployed API URL for staging / production.
VITE_API_URL=http://localhost:8000
